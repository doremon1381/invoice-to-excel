{
  "expo": {
    "name": "invoice-to-excel-expo",
    "slug": "invoice-to-excel-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "invoicetoexcelexpo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Invoice Scanner to use your camera to scan invoices.",
        "NSPhotoLibraryUsageDescription": "Allow Invoice Scanner to access your photo library to import invoice images.",
        "NSPhotoLibraryAddUsageDescription": "Allow Invoice Scanner to save exported invoice files when needed."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.doremon1380.invoicetoexcelexpo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Invoice Scanner to use your camera to scan invoices."
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "googleIosClientId": "947812351845-vil8lcpn0hcuenkufcvpee6isoquneiv.apps.googleusercontent.com",
      "googleAndroidClientId": "947812351845-vil8lcpn0hcuenkufcvpee6isoquneiv.apps.googleusercontent.com",
      "googleWebClientId": "947812351845-vil8lcpn0hcuenkufcvpee6isoquneiv.apps.googleusercontent.com"
    }
  }
}
