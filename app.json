{
  "expo": {
    "name": "invoice-to-excel-expo",
    "slug": "invoice-to-excel-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.doremon1380.invoicetoexcelexpo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.doremon1380.invoicetoexcelexpo",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Invoice Scanner to use your camera to scan invoices.",
        "NSPhotoLibraryUsageDescription": "Allow Invoice Scanner to access your photo library to import invoice images.",
        "NSPhotoLibraryAddUsageDescription": "Allow Invoice Scanner to save exported invoice files when needed."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.doremon1380.invoicetoexcelexpo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Invoice Scanner to use your camera to scan invoices."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.435208614905-t4y2et16fe2mmu4f7meabumjues7k2of"
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-localization",
      "expo-dev-client"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "googleIosClientId": "435208614905-t4y2et16fe2mmu4f7meabumjues7k2of.apps.googleusercontent.com",
      "googleWebClientId": "435208614905-1550v87778r39vrb0ncinfdplbqjsm4q.apps.googleusercontent.com",
      "router": {},
      "eas": {
        "projectId": "77c7a5bf-b52b-42fb-b24a-ce1fcf81401b"
      }
    }
  }
}
